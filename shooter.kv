#: set color_cosmos 0.2, 0, 0.1, 1
<MainScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: '30dp'
        spacing: '10dp'
        MDIconButton:
            icon:'cog'
            pos_hint:{'top':1,"right":1}
            icon_size:"48dp"
        MDLabel:
            text: "SHOOTER"
            font_style:"H2"
            halign:'center'
        Image:
            source: "assets/player.png"
            size_hint_y: 0.6
            allow_stretch:True
            pos_hint:{"center_x":0.5,"center_y":0.5}
        MDFillRoundFlatButton:
            text: "PLAY"
            font_size: '50sp'
            pos_hint: {'center_x': 0.5}
            on_release:
                app.root.current="game"
<PlayerShip>:
    source:"assets/player.png"
    size_hint: None, None
    size: dp(100), dp(100)
<EnemyShip>:
    source:"assets/enemi.png"
    size_hint: None, None
    size: dp(60), dp(60)
<GameOverScreen>:
    MDFloatLayout:
        md_bg_color: color_cosmos
        MDBoxLayout:
            orientation: 'vertical'
            padding: '30dp'
            spacing: '10dp'
            MDLabel:
                text: "GAME OVER"
                font_style:"H2"
                halign:'center'
            MDFillRoundFlatButton:
                text: "RESTART"
                font_size: '50sp'
                pos_hint: {'center_x': 0.5}
                on_release:
                    app.root.current="game"
<GameScreen>:
    MDFloatLayout:
        md_bg_color: color_cosmos
        MDFloatLayout:
            id: game
            MDFloatLayout:
                id:back
            MDFloatLayout:
                id: front
                PlayerShip:
                    id: ship
                    center:root.center_x,dp(150)
        MDFloatLayout:
            id: interface
            MDBoxLayout:
                spacing: dp(10)
                padding: dp(10)
                MDFloatingActionButton:
                    icon: "arrow-left-bold"
                    on_press: root.press_key("left")
                    on_release: root.release_key("left")
                    md_bg_color: app.theme_cls.primary_color
                MDFloatingActionButton:
                    icon: "arrow-right-bold"
                    md_bg_color: app.theme_cls.primary_color
                    on_press: root.press_key("right")
                    on_release: root.release_key("right")
                Widget:
                MDFloatingActionButton:
                    icon: "crosshairs-gps"
                    md_bg_color: app.theme_cls.primary_color
                    on_press: root.press_key("shot")
                    on_release: root.release_key("shot")